def validate_schema(table_name: str, incoming_df) -> None:
    """Raises RuntimeError if required columns missing or wrong type."""
    result = compare_schema(table_name, incoming_df)
    if result["missing_cols"]:
        raise RuntimeError(f"Schema drift: missing {result['missing_cols']}")
 
