13.3 dq_profiler
Called only from nb_bronze_to_silver. Compares raw Bronze DataFrame against cleaned Silver DataFrame to compute anomaly statistics.
# /Shared/pet-analytics/shared/dq_profiler
 
def profile_dataframe(raw_df, clean_df, table_name, run_id, load_date) -> dict:
    total_input   = raw_df.count()
    null_count    = _count_nulls(raw_df)
    dup_count     = _count_duplicates(raw_df, table_name)
    oor_count     = _count_out_of_range(raw_df, table_name)
    total_anomalies = null_count + dup_count + oor_count
    clean_count   = clean_df.count()
    anomaly_rate  = round(total_anomalies/total_input*100, 2) if total_input > 0 else 0.0
 
    # DQ status thresholds
    if clean_count == 0:          dq_status = "FAILED"
    elif anomaly_rate > 10.0:     dq_status = "WARNING"
    elif (total_input-clean_count)/max(total_input,1) > 0.20: dq_status = "WARNING"
    else:                         dq_status = "PASSED"
 
    write_dq_run(Row(run_id=run_id, table_name=table_name, load_date=load_date,
        total_input_rows=total_input, null_rows_found=null_count,
        duplicate_rows_found=dup_count, out_of_range_rows_found=oor_count,
        total_anomalies_fixed=total_anomalies, clean_rows_written=clean_count,
        anomaly_rate_pct=anomaly_rate, dq_status=dq_status))
    return {"dq_status":dq_status,"anomaly_rate_pct":anomaly_rate}

