12.3 aggregator
All groupBy and agg logic lives here. Organised by domain audience.
# /Shared/pet-analytics/gold/aggregator
 
from pyspark.sql.functions import col, sum, avg, max, min, count, when, round as R, to_date
 
# ── Pet Owner aggregations ────────────────────────────────
def agg_activity_daily(df):
    return (df.withColumn("date", to_date(col("snapshot_timestamp")))
              .groupBy("pet_id","date")
              .agg(sum("steps").alias("total_steps"),
                   sum("distance_km").alias("total_distance_km"),
                   sum("active_minutes").alias("total_active_minutes")))
 
def agg_health_daily(df):
    return (df.withColumn("date", to_date(col("snapshot_timestamp")))
              .groupBy("pet_id","date")
              .agg(R(avg("heart_rate"),2).alias("avg_heart_rate"),
                   R(avg("body_temperature"),2).alias("avg_body_temperature"),
                   max("heart_rate").alias("max_heart_rate"),
                   min("heart_rate").alias("min_heart_rate"),
                   sum(when((col("heart_rate").isNull())|(col("body_temperature")>41.5),1).otherwise(0)).alias("health_alert_count"))
              .withColumn("has_health_alert", when(col("health_alert_count")>0, True).otherwise(False)))
 
# ── Manufacturer aggregations ─────────────────────────────
def agg_failures_by_device(df):
    return (df.groupBy("device_id")
              .agg(count("failure_id").alias("total_failures"),
                   R(avg("severity_score"),2).alias("avg_severity_score"),
                   sum("downtime_minutes").alias("total_downtime_minutes"),
                   when(count("failure_id")>5, True).otherwise(False).alias("is_crash_prone")))
 
def agg_firmware_by_device(df):
    return (df.groupBy("device_id")
              .agg(count("deployment_id").alias("total_deployments"),
                   sum(when(col("deployment_status")=="Success",1).otherwise(0)).alias("successful_deployments"),
                   sum(when(col("rollback_flag")==True,1).otherwise(0)).alias("total_rollbacks"))
              .withColumn("fw_success_rate_pct",
                   R(col("successful_deployments")/col("total_deployments")*100,1)))
 
# ── Sales aggregation ─────────────────────────────────────
def agg_sales_summary(df):
    return (df.groupBy("sale_month","sales_channel","device_category","country","state")
              .agg(count("sale_id").alias("total_units_sold"),
                   R(sum("sale_price"),2).alias("gross_revenue"),
                   R(sum("net_revenue"),2).alias("net_revenue"),
                   R(sum("discount_amount"),2).alias("total_discounts"),
                   R(sum("discount_amount")/sum("sale_price")*100,1).alias("discount_rate_pct")))

12.4 gold_writer
Writes managed Unity Catalog tables using saveAsTable(). Always overwrites. Applies null defaults via coalesce for additive metrics. Vital sign nulls (heart_rate, temperature) are preserved — NULL means the pet has no health monitor device, which is meaningful.
# /Shared/pet-analytics/gold/gold_writer
 
from pyspark.sql.functions import current_timestamp, coalesce, lit
 
def write_gold(df, gold_table_name: str) -> int:
    full_table = f"petiot_dbx_dev.gold.{gold_table_name}"
    (df.write
       .format("delta")
       .mode("overwrite")
       .option("overwriteSchema", "true")
       .option("mergeSchema",     "true")
       .saveAsTable(full_table))
    return spark.table(full_table).count()
 
def apply_null_defaults(df, gold_table_name):
    """Coalesce additive metrics to 0. Keep vital signs as NULL."""
    fill_map = {
        "gold_pet_owner_daily_summary": {
            "total_steps":0, "total_distance_km":0.0,
            "total_active_minutes":0, "health_alert_count":0,
            "total_food_grams":0.0, "total_feed_sessions":0,
            "total_water_ml":0.0, "total_drink_sessions":0,
            # avg_heart_rate, avg_body_temperature LEFT AS NULL
        },
    }
    for col_name, default in fill_map.get(gold_table_name, {}).items():
        if col_name in df.columns:
            df = df.withColumn(col_name, coalesce(df[col_name], lit(default)))
    return df

