10.4 autoloader
Builds source paths and checkpoint paths. Returns streaming DataFrame (Auto Loader) for incremental fact loads, or batch DataFrame for dimension full refreshes.
# /Shared/pet-analytics/bronze/autoloader
 
def build_source_path(table_name: str, table_type: str) -> str:
    # Dimensions: flat file at root
    if table_type == "dimension":
        return abfss("raw", f"{table_name}.json")
    # Facts: partitioned folder — Auto Loader walks all year=/month=/day=/
    return abfss("raw", f"{table_name}/")
 
def build_checkpoint_path(table_name: str) -> str:
    return abfss("checkpoints", f"bronze/{table_name}/")
 
def read_stream(table_name: str, table_type: str, schema) -> object:
    """Auto Loader streaming read for incremental fact ingestion."""
    return (spark.readStream
        .format("cloudFiles")
        .option("cloudFiles.format",           "json")
        .option("cloudFiles.schemaLocation",   abfss("checkpoints", f"schemas/{table_name}/"))
        .option("cloudFiles.inferColumnTypes", "false")  # use our explicit schema
        .option("multiLine",                   "true")
        .option("recursiveFileLookup",          "true")  # walk year=/month=/day=/
        .schema(schema)
        .load(build_source_path(table_name, table_type))
    )
 
# NOTE: cloudFiles.schemaEvolutionMode = addNewColumns was removed.
# It is incompatible with explicit .schema() on DBR 13.3.
# schema_manager handles evolution via validate_schema() instead.
 
def read_batch(table_name, table_type, schema, load_date=None):
    """Batch read for dimensions or specific date partition."""
    if table_type == "dimension":
        source_path = build_source_path(table_name, table_type)
    elif load_date:
        y, m, d = load_date.split("-")
        source_path = abfss("raw", f"{table_name}/year={y}/month={m}/day={d}/")
        # Guard: return empty DataFrame if partition does not exist
        try:
            dbutils.fs.ls(source_path)
        except:
            print(f"[autoloader] No partition for {table_name} on {load_date} — skipping")
            return spark.createDataFrame([], schema)
    return spark.read.option("multiLine","true").option("recursiveFileLookup","true")
           .schema(schema).json(source_path)
 
print("[autoloader] Loaded.")

10.5 lineage
Injects exactly 6 audit columns into every Bronze row. The _source_file column is particularly important — it records the exact ADLS path the row came from, enabling partition-level traceability.
# /Shared/pet-analytics/bronze/lineage
 
from pyspark.sql.functions import current_timestamp, input_file_name, lit
 
def add_lineage_columns(df, table_name: str, load_date: str, table_type: str):
    return (df
        .withColumn("_bronze_load_timestamp", current_timestamp())
        .withColumn("_source_file",           input_file_name())
        # input_file_name() for fact rows resolves to e.g.:
        # abfss://raw@petiot.../device_snapshots/year=2025/month=01/day=03/device_snapshots.json
        .withColumn("_load_date",             lit(load_date))
        .withColumn("_table_name",            lit(table_name))
        .withColumn("_table_type",            lit(table_type))
        .withColumn("_is_quarantined",        lit(False))
    )
 
print("[lineage] Loaded. Columns:", ["_bronze_load_timestamp","_source_file",
       "_load_date","_table_name","_table_type","_is_quarantined"])

10.6 writer
Handles all Delta writes. writeStream for fact tables (Auto Loader trigger availableNow=True), write.format("delta") for dimension full overwrites.
# /Shared/pet-analytics/bronze/writer
 
def write_stream(df, table_name: str, checkpoint_path: str) -> None:
    """Streaming write — processes all queued files then stops (availableNow=True)."""
    bronze_path = abfss("bronze", table_name)
    (df.writeStream
       .format("delta")
       .outputMode("append")
       .option("checkpointLocation", checkpoint_path)
       .option("mergeSchema", "true")
       .trigger(availableNow=True)  # processes queue then terminates
       .start(bronze_path)
       .awaitTermination())
 
def write_batch(df, table_name: str) -> None:
    """Full overwrite for dimension tables."""
    bronze_path = abfss("bronze", table_name)
    (df.write.format("delta").mode("overwrite")
       .option("overwriteSchema", "true").save(bronze_path))
 
def get_bronze_row_count(table_name: str) -> int:
    return spark.read.format("delta").load(abfss("bronze", table_name)).count()
 
print("[writer] Loaded.")

