8.3 nb_partition_raw_fact_tables Notebook
This utility notebook reads each flat fact JSON file from raw/, partitions it by the relevant date/timestamp column, writes day-partitioned JSON files, renames Spark's part-* files to clean table_name.json, and deletes the original flat file.
# Notebook: /Shared/pet-analytics/shared/nb_partition_raw_fact_tables
 
from pyspark.sql.functions import year, month, dayofmonth, to_timestamp, lpad
 
FACT_TABLES = {
    "sales":                "sale_date",
    "device_snapshots":     "snapshot_timestamp",
    "activity_snapshots":   "snapshot_timestamp",
    "health_snapshots":     "snapshot_timestamp",
    "feeding_events":       "event_timestamp",
    "hydration_events":     "event_timestamp",
    "device_failures":      "failure_timestamp",
    "firmware_deployments": "deployment_timestamp",
}
 
for table_name, ts_col in FACT_TABLES.items():
    flat_file = abfss("raw", f"{table_name}.json")
    out_path  = abfss("raw", table_name)
 
    df = (spark.read
          .option("multiLine", "true")
          .option("inferSchema", "true")
          .json(flat_file))
 
    # Derive zero-padded partition columns
    df = (df
          .withColumn("_ts",   to_timestamp(col(ts_col)))
          .withColumn("year",  year("_ts").cast("string"))
          .withColumn("month", lpad(month("_ts").cast("string"), 2, "0"))
          .withColumn("day",   lpad(dayofmonth("_ts").cast("string"), 2, "0"))
          .drop("_ts"))
 
    # Write partitioned
    (df.repartition(col("year"), col("month"), col("day"))
       .write.partitionBy("year","month","day")
       .mode("overwrite")
       .json(out_path))
 
    # Delete original flat file
    dbutils.fs.rm(flat_file, recurse=False)
 
   
  
 

